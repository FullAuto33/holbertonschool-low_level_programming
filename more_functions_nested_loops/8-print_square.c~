#include "main.h"

/**
 * print_square - function that prints a square, followed by a new line.
 * @size: is the size of the square
 *
 * Return: Always 0.
*/

void print_square(int size)
{

if (size <= 0)
{
_putchar('\n');
}
else
{
int idx1, idx2;
for (idx1 = 0; idx1 < size; idx1++)
{
for (idx2 = 0; idx2 < size; idx2++)
{
_putchar('#');
}
_putchar("\n");
}
}
}

/**
 * print_triangle -  function that prints a triangle, followed by a new line.
 * @size:  is the size of the triangle
 *
 * Return: Always 0.
*/

void print_triangle(int size)
{
int i, j;
if (size == 0)
{
_putchar('\n');
}
else
{
for (i = 1; i <= size; i++)
{
for (j = 1; j <= i; j++)
{
_putchar('#');
}
_putchar('\n');
}
}
}





#include "main.h"

/**
 * print_line - function that draws a straight line in the terminal.
 * @n: is the number of times the character _ should be printed
 *
 * Return: Always 0.
*/


void print_line(int n)
{
int compteur;
if (n <= 0)
{
_putchar('\n');
}
else
{
for (compteur = 0; compteur < n, compteur++)
{
_putchar('_');
}
_putchar('\n');
}
}
